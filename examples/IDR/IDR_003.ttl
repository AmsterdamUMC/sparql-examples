@prefix ex: <https://www.amsterdamumc.nl/NS/sparqlExamples/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix w3: <http://www.w3.org/2000/01/rdf-schema#> .

ex:IDR_002 a sh:SPARQLExecutable,
        sh:SPARQLSelectExecutable ;
    rdfs:comment "All properties that capture annotations?"@en ;
    sh:prefixes _:sparql_examples_prefixes ;
    sh:select """PREFIX core: <https://ld.openmicroscopy.org/core/>

SELECT DISTINCT ?key (COUNT(DISTINCT ?entry) AS ?count)
WHERE {
  ?ann a core:MapAnnotation .
  ?ann core:mapEntry ?entry .
  ?entry core:key ?key .
}
GROUP BY ?key
ORDER BY DESC(?count)

""" ;
    schema:keywords "IDR"@en ;
    schema:keywords "Omero"@en ;
    schema:keywords "Imaging"@en ;
    schema:target <http://81.24.10.88:8080> .
